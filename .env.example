# =================================================================
# RAY environment variables
# =================================================================
# Copy this file to `.env.local` for local development, or set these
# values in your cloud provider's environment-variables UI for prod.
# =================================================================

# Gmail SMTP credentials for sending OTP emails.
# 1. Sign in to the Gmail account you want to send from.
# 2. Enable 2-Step Verification at https://myaccount.google.com/security
# 3. Generate an App Password at https://myaccount.google.com/apppasswords
# 4. Paste the 16-character code into EMAIL_PASSWORD below (spaces are stripped).
EMAIL_USER=connectwithvexar@gmail.com
EMAIL_PASSWORD=kfcqdwexgpmkxbhr

# Public base URL of your deployment. Used to build absolute image URLs in
# transactional emails so the RAY mascot renders reliably in every webmail
# client. Examples:
#   Local dev:   leave UNSET (the email falls back to inline CID attachment)
#   Vercel:      https://your-app.vercel.app
#   Custom:      https://app.vexar.tech
PUBLIC_BASE_URL=
